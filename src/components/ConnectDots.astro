---
import '../styles/connect-dots.css';
---

<div class="dots-game">
  <div class="prompt-area">
    <span class="prompt-text">Find:</span>
    <span class="next-number" id="next-number">1</span>
  </div>
  <div class="canvas-wrapper" id="canvas-wrapper">
    <canvas id="dots-canvas" role="img" aria-label="Connect the dots game canvas"></canvas>
  </div>
  <div class="score-area">
    <span id="score">0</span> shapes drawn!
  </div>
  <button class="next-btn hidden" id="next-btn">NEXT!</button>
</div>

<script>
  import { playPop, playBoing, playWhoosh, playCheer, speakPhrase } from '../utils/sounds.js';

  interface Point { x: number; y: number; }
  interface Shape { name: string; emoji: string; points: Point[]; }

  const SHAPES: Shape[] = [
    {
      name: 'Star',
      emoji: '⭐',
      points: [
        { x: 0.5, y: 0.05 },
        { x: 0.38, y: 0.35 },
        { x: 0.05, y: 0.35 },
        { x: 0.32, y: 0.55 },
        { x: 0.22, y: 0.9 },
        { x: 0.5, y: 0.7 },
        { x: 0.78, y: 0.9 },
        { x: 0.68, y: 0.55 },
        { x: 0.95, y: 0.35 },
        { x: 0.62, y: 0.35 },
      ],
    },
    {
      name: 'House',
      emoji: '🏠',
      points: [
        { x: 0.5, y: 0.08 },
        { x: 0.15, y: 0.4 },
        { x: 0.15, y: 0.92 },
        { x: 0.42, y: 0.92 },
        { x: 0.42, y: 0.65 },
        { x: 0.58, y: 0.65 },
        { x: 0.58, y: 0.92 },
        { x: 0.85, y: 0.92 },
        { x: 0.85, y: 0.4 },
        { x: 0.5, y: 0.08 },
      ],
    },
    {
      name: 'Arrow',
      emoji: '🚀',
      points: [
        { x: 0.5, y: 0.05 },
        { x: 0.65, y: 0.35 },
        { x: 0.58, y: 0.35 },
        { x: 0.58, y: 0.65 },
        { x: 0.72, y: 0.65 },
        { x: 0.72, y: 0.8 },
        { x: 0.58, y: 0.8 },
        { x: 0.58, y: 0.92 },
        { x: 0.42, y: 0.92 },
        { x: 0.42, y: 0.35 },
      ],
    },
    {
      name: 'Diamond',
      emoji: '💎',
      points: [
        { x: 0.5, y: 0.08 },
        { x: 0.78, y: 0.28 },
        { x: 0.92, y: 0.52 },
        { x: 0.72, y: 0.74 },
        { x: 0.5, y: 0.92 },
        { x: 0.28, y: 0.74 },
        { x: 0.08, y: 0.52 },
        { x: 0.22, y: 0.28 },
      ],
    },
    {
      name: 'Cup',
      emoji: '☕',
      points: [
        { x: 0.18, y: 0.12 },
        { x: 0.82, y: 0.12 },
        { x: 0.82, y: 0.42 },
        { x: 0.72, y: 0.88 },
        { x: 0.5, y: 0.92 },
        { x: 0.28, y: 0.88 },
        { x: 0.18, y: 0.42 },
      ],
    },
  ];

  const canvas = document.getElementById('dots-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  const wrapper = document.getElementById('canvas-wrapper')!;
  const nextNumberEl = document.getElementById('next-number')!;
  const scoreEl = document.getElementById('score')!;
  const nextBtn = document.getElementById('next-btn')!;

  let currentShape: Shape;
  let points: Point[] = [];
  let connectedCount = 0;
  let score = 0;
  let roundActive = false;
  const recentShapes: number[] = [];
  const DOT_RADIUS = 20;
  const HIT_RADIUS = 35;

  function resizeCanvas() {
    const dpr = window.devicePixelRatio || 1;
    canvas.width = wrapper.clientWidth * dpr;
    canvas.height = wrapper.clientHeight * dpr;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    if (currentShape) {
      scalePoints();
      drawScene();
    }
  }

  function scalePoints() {
    const w = wrapper.clientWidth;
    const h = wrapper.clientHeight;
    const pad = 40;
    const minSpacing = HIT_RADIUS * 2 + 8;

    let scale = 1;
    for (let attempt = 0; attempt < 6; attempt++) {
      const rangeW = (w - pad * 2) * scale;
      const rangeH = (h - pad * 2) * scale;
      const offsetX = (w - rangeW) / 2 - pad * scale + pad;
      const offsetY = (h - rangeH) / 2 - pad * scale + pad;

      const scaled = currentShape.points.map(p => ({
        x: offsetX + p.x * rangeW,
        y: offsetY + p.y * rangeH,
      }));

      let minDist = Infinity;
      for (let i = 0; i < scaled.length; i++) {
        for (let j = i + 1; j < scaled.length; j++) {
          const d = Math.hypot(scaled[i].x - scaled[j].x, scaled[i].y - scaled[j].y);
          if (d < minDist) minDist = d;
        }
      }

      if (minDist >= minSpacing || attempt === 5) {
        points = scaled;
        return;
      }
      scale *= minSpacing / minDist;
    }
  }

  function drawScene() {
    const w = wrapper.clientWidth;
    const h = wrapper.clientHeight;
    ctx.clearRect(0, 0, w, h);

    // Draw connected lines
    if (connectedCount > 1) {
      ctx.beginPath();
      ctx.moveTo(points[0].x, points[0].y);
      for (let i = 1; i < connectedCount; i++) {
        ctx.lineTo(points[i].x, points[i].y);
      }
      ctx.strokeStyle = '#4ECDC4';
      ctx.lineWidth = 4;
      ctx.shadowColor = '#4ECDC4';
      ctx.shadowBlur = 8;
      ctx.stroke();
      ctx.shadowBlur = 0;
    }

    // Draw all dots
    for (let i = 0; i < points.length; i++) {
      const p = points[i];
      const isConnected = i < connectedCount;
      const isNext = i === connectedCount;

      ctx.beginPath();
      ctx.arc(p.x, p.y, isConnected ? 14 : DOT_RADIUS, 0, Math.PI * 2);

      if (isNext) {
        ctx.fillStyle = '#FF6B6B';
        ctx.shadowColor = '#FF6B6B';
        ctx.shadowBlur = 12;
      } else if (isConnected) {
        ctx.fillStyle = '#6BCB77';
        ctx.shadowBlur = 0;
      } else {
        ctx.fillStyle = '#4ECDC4';
        ctx.shadowBlur = 0;
      }

      ctx.fill();
      ctx.shadowBlur = 0;

      ctx.fillStyle = 'white';
      ctx.font = 'bold 14px Nunito, sans-serif';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(String(i + 1), p.x, p.y);
    }
  }

  function drawReveal() {
    const w = wrapper.clientWidth;
    const h = wrapper.clientHeight;

    // Fill the shape
    ctx.beginPath();
    ctx.moveTo(points[0].x, points[0].y);
    for (let i = 1; i < points.length; i++) {
      ctx.lineTo(points[i].x, points[i].y);
    }
    ctx.closePath();
    ctx.fillStyle = 'rgba(255, 217, 61, 0.35)';
    ctx.fill();

    // Redraw lines on top
    ctx.beginPath();
    ctx.moveTo(points[0].x, points[0].y);
    for (let i = 1; i < points.length; i++) {
      ctx.lineTo(points[i].x, points[i].y);
    }
    ctx.strokeStyle = '#4ECDC4';
    ctx.lineWidth = 4;
    ctx.shadowColor = '#4ECDC4';
    ctx.shadowBlur = 8;
    ctx.stroke();
    ctx.shadowBlur = 0;

    // Draw emoji
    const cx = points.reduce((s, p) => s + p.x, 0) / points.length;
    const cy = points.reduce((s, p) => s + p.y, 0) / points.length;
    ctx.font = '48px sans-serif';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText(currentShape.emoji, cx, cy);
  }

  function getCanvasCoords(e: PointerEvent | Touch): { x: number; y: number } {
    const rect = canvas.getBoundingClientRect();
    return {
      x: e.clientX - rect.left,
      y: e.clientY - rect.top,
    };
  }

  function handleTap(e: PointerEvent | Touch) {
    if (!roundActive) return;

    const { x, y } = getCanvasCoords(e as PointerEvent);
    const nextIdx = connectedCount;
    if (nextIdx >= points.length) return;

    const p = points[nextIdx];
    const dist = Math.sqrt((x - p.x) ** 2 + (y - p.y) ** 2);

    if (dist <= HIT_RADIUS) {
      connectedCount++;
      playPop();
      speakPhrase(String(connectedCount));
      drawScene();

      if (connectedCount === points.length) {
        roundActive = false;
        playWhoosh();
        setTimeout(() => {
          drawReveal();
          playCheer();
          score++;
          scoreEl.textContent = String(score);
          nextBtn.classList.remove('hidden');
        }, 300);
      }
    } else {
      playBoing();
    }
  }

  canvas.addEventListener('pointerdown', (e) => {
    e.preventDefault();
    handleTap(e);
  });

  function startRound() {
    let idx: number;
    do {
      idx = Math.floor(Math.random() * SHAPES.length);
    } while (recentShapes.includes(idx));
    recentShapes.push(idx);
    if (recentShapes.length > 3) recentShapes.shift();

    currentShape = SHAPES[idx];
    connectedCount = 0;
    roundActive = true;
    nextBtn.classList.add('hidden');
    nextNumberEl.textContent = '1';

    resizeCanvas();
    speakPhrase('Connect the dots from 1 to 10!');
  }

  nextBtn.addEventListener('click', startRound);

  window.addEventListener('resize', resizeCanvas);
  startRound();
</script>
