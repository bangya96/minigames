---
import '../styles/balloon-pop.css';
---

<div class="balloon-game">
  <div class="prompt-area">
    <span class="prompt-text">Find the letter</span>
    <span class="target-letter" id="target-letter">A</span>
    <button class="speaker-btn" id="speak-btn" aria-label="Hear the letter">🔊</button>
  </div>

  <div class="score-area">
    <span id="score">0</span> stars!
  </div>

  <div class="balloon-field" id="balloon-field"></div>

  <canvas id="confetti-canvas"></canvas>

  <button class="next-btn hidden" id="next-btn">NEXT!</button>
</div>

<script>
  import { playPop, playCheer, playBoing, speakLetter } from '../utils/sounds.js';

  const LETTERS = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('');
  const MAX_ON_SCREEN = 8;
  const SPAWN_INTERVAL_MS = 1400;
  const FLOAT_MIN_S = 16;
  const FLOAT_MAX_S = 22;

  let targetLetter = '';
  let score = 0;
  let roundActive = false;
  let spawnTimer: number | null = null;

  const balloonField = document.getElementById('balloon-field')!;
  const targetEl = document.getElementById('target-letter')!;
  const scoreEl = document.getElementById('score')!;
  const nextBtn = document.getElementById('next-btn')!;
  const speakBtn = document.getElementById('speak-btn')!;
  const canvas = document.getElementById('confetti-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  function resizeCanvas() {
    canvas.width = canvas.offsetWidth;
    canvas.height = canvas.offsetHeight;
  }
  resizeCanvas();
  window.addEventListener('resize', resizeCanvas);

  function shuffle<T>(arr: T[]): T[] {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  function spawnConfetti() {
    const particles: { x: number; y: number; vx: number; vy: number; color: string; size: number; life: number }[] = [];
    const confettiColors = ['#FF6B6B', '#4ECDC4', '#FFD93D', '#6BCB77', '#9B59B6', '#FF8E53'];

    for (let i = 0; i < 40; i++) {
      particles.push({
        x: canvas.width / 2 + (Math.random() - 0.5) * 100,
        y: canvas.height / 2,
        vx: (Math.random() - 0.5) * 12,
        vy: -Math.random() * 10 - 5,
        color: confettiColors[Math.floor(Math.random() * confettiColors.length)],
        size: Math.random() * 8 + 4,
        life: 1,
      });
    }

    function animate() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      let alive = false;

      for (const p of particles) {
        if (p.life <= 0) continue;
        alive = true;
        p.x += p.vx;
        p.y += p.vy;
        p.vy += 0.3;
        p.life -= 0.015;

        ctx.globalAlpha = p.life;
        ctx.fillStyle = p.color;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
        ctx.fill();
      }

      if (alive) {
        requestAnimationFrame(animate);
      } else {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
      }
    }

    requestAnimationFrame(animate);
  }

  function createBalloon(letter: string): HTMLDivElement {
    const balloon = document.createElement('div');
    balloon.className = 'balloon';
    balloon.textContent = letter;
    balloon.dataset.letter = letter;

    const xPosition = 5 + Math.random() * 80; // 5%..85%
    const duration = FLOAT_MIN_S + Math.random() * (FLOAT_MAX_S - FLOAT_MIN_S);
    const drift = (Math.random() - 0.5) * 60;

    balloon.style.setProperty('--x-position', `${xPosition}%`);
    balloon.style.setProperty('--duration', `${duration}s`);
    balloon.style.setProperty('--drift', `${drift}px`);
    balloon.style.animationDelay = '0s';

    balloon.addEventListener('click', () => handleBalloonClick(balloon, letter));
    balloon.addEventListener('touchstart', (e) => {
      e.preventDefault();
      handleBalloonClick(balloon, letter);
    }, { passive: false });

    balloon.addEventListener('animationend', (e) => {
      if ((e as AnimationEvent).animationName !== 'float-up') return;
      balloon.remove();
    });

    return balloon;
  }

  function liveBalloons(): HTMLDivElement[] {
    return (Array.from(balloonField.children) as HTMLDivElement[]).filter(
      (b) => !b.classList.contains('popping'),
    );
  }

  function pickSpawnLetter(): string {
    const live = liveBalloons();
    const hasTarget = live.some((b) => b.dataset.letter === targetLetter);
    // Always keep target letter present on screen.
    if (!hasTarget) return targetLetter;
    // Otherwise mostly distractors, occasional target.
    if (Math.random() < 0.3) return targetLetter;
    const pool = LETTERS.filter((l) => l !== targetLetter);
    return pool[Math.floor(Math.random() * pool.length)];
  }

  function spawnTick() {
    if (!roundActive) return;
    if (liveBalloons().length >= MAX_ON_SCREEN) return;
    const letter = pickSpawnLetter();
    balloonField.appendChild(createBalloon(letter));
  }

  function startSpawning() {
    stopSpawning();
    spawnTimer = window.setInterval(spawnTick, SPAWN_INTERVAL_MS);
  }

  function stopSpawning() {
    if (spawnTimer !== null) {
      window.clearInterval(spawnTimer);
      spawnTimer = null;
    }
  }

  function handleBalloonClick(balloon: HTMLDivElement, letter: string) {
    if (!roundActive) return;
    if (balloon.classList.contains('popping') || balloon.classList.contains('wobble')) return;

    if (letter === targetLetter) {
      roundActive = false;
      stopSpawning();
      balloon.classList.add('popping');
      playPop();
      setTimeout(playCheer, 150);
      spawnConfetti();
      score++;
      scoreEl.textContent = String(score);
      nextBtn.classList.remove('hidden');
    } else {
      balloon.classList.add('wobble');
      playBoing();
      setTimeout(() => balloon.classList.remove('wobble'), 400);
    }
  }

  function startRound() {
    stopSpawning();
    roundActive = true;
    nextBtn.classList.add('hidden');
    balloonField.innerHTML = '';

    targetLetter = LETTERS[Math.floor(Math.random() * LETTERS.length)];
    targetEl.textContent = targetLetter;

    // Seed a few balloons immediately at staggered heights so the field
    // isn't empty while waiting for the spawn timer.
    const seedCount = 4;
    const seedLetters = [targetLetter];
    const pool = shuffle(LETTERS.filter((l) => l !== targetLetter));
    for (let i = 0; i < seedCount - 1; i++) seedLetters.push(pool[i]);
    shuffle(seedLetters).forEach((letter) => {
      const balloon = createBalloon(letter);
      // Stagger initial vertical progress so they don't all appear at the bottom.
      balloon.style.animationDelay = `-${Math.random() * (FLOAT_MIN_S * 0.6)}s`;
      balloonField.appendChild(balloon);
    });

    startSpawning();
    speakLetter(targetLetter);
  }

  speakBtn.addEventListener('click', () => {
    speakLetter(targetLetter);
  });

  nextBtn.addEventListener('click', () => {
    startRound();
  });

  startRound();
</script>
