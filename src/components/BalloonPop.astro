---
import '../styles/balloon-pop.css';
---

<div class="balloon-game">
  <div class="prompt-area">
    <span class="prompt-text" id="prompt-label">Find the letter</span>
    <span class="target-letter" id="target-letter">A</span>
    <button class="speaker-btn" id="speak-btn" aria-label="Hear the prompt">🔊</button>
  </div>

  <div class="game-stats-bar">
    <span id="stage-display">Stage 1/10</span>
    <span>Score: <span id="score">0</span></span>
  </div>

  <div class="balloon-field" id="balloon-field"></div>

  <canvas id="confetti-canvas"></canvas>

  <button class="next-btn hidden" id="next-btn">NEXT!</button>
</div>

<script>
  import { playPop, playCheer, playBoing, speakLetter, speakPhrase } from '../utils/sounds.js';
  import { getSavedScore, saveScore, calculateStage } from '../utils/storage.js';

  const LETTERS = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('');
  const BASE_FLOAT_MIN = 16;
  const BASE_FLOAT_MAX = 22;

  let targetLetters: string[] = [];
  let targetsToPop: string[] = [];
  let score = getSavedScore('balloon-pop');
  let roundActive = false;
  let spawnTimer: number | null = null;

  const balloonField = document.getElementById('balloon-field')!;
  const promptLabel = document.getElementById('prompt-label')!;
  const targetEl = document.getElementById('target-letter')!;
  const scoreEl = document.getElementById('score')!;
  const stageEl = document.getElementById('stage-display')!;
  const nextBtn = document.getElementById('next-btn')!;
  const speakBtn = document.getElementById('speak-btn')!;
  const canvas = document.getElementById('confetti-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  function updateStats() {
    scoreEl.textContent = String(score);
    stageEl.textContent = `Stage ${calculateStage(score)}/10`;
  }
  updateStats();

  function resizeCanvas() {
    canvas.width = canvas.offsetWidth;
    canvas.height = canvas.offsetHeight;
  }
  resizeCanvas();
  window.addEventListener('resize', resizeCanvas);

  function shuffle<T>(arr: T[]): T[] {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  function getStageConfig(stage: number) {
    if (stage === 1) return { targets: 1, maxBalloons: 2, spawnRate: 1600 };
    if (stage === 2) return { targets: 1, maxBalloons: 4, spawnRate: 1400 };
    if (stage === 3) return { targets: 1, maxBalloons: 8, spawnRate: 1200 };
    if (stage === 4) return { targets: 2, maxBalloons: 4, spawnRate: 1400 };
    if (stage === 5) return { targets: 2, maxBalloons: 6, spawnRate: 1200 };
    if (stage === 6) return { targets: 2, maxBalloons: 8, spawnRate: 1100 };
    if (stage === 7) return { targets: 3, maxBalloons: 5, spawnRate: 1300 };
    if (stage === 8) return { targets: 3, maxBalloons: 8, spawnRate: 1100 };
    if (stage === 9) return { targets: 3, maxBalloons: 10, spawnRate: 900 };
    return { targets: 4, maxBalloons: 10, spawnRate: 900 };
  }

  function spawnConfetti() {
    const particles: { x: number; y: number; vx: number; vy: number; color: string; size: number; life: number }[] = [];
    const confettiColors = ['#FF6B6B', '#4ECDC4', '#FFD93D', '#6BCB77', '#9B59B6', '#FF8E53'];

    for (let i = 0; i < 40; i++) {
      particles.push({
        x: canvas.width / 2 + (Math.random() - 0.5) * 100,
        y: canvas.height / 2,
        vx: (Math.random() - 0.5) * 12,
        vy: -Math.random() * 10 - 5,
        color: confettiColors[Math.floor(Math.random() * confettiColors.length)],
        size: Math.random() * 8 + 4,
        life: 1,
      });
    }

    function animate() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      let alive = false;

      for (const p of particles) {
        if (p.life <= 0) continue;
        alive = true;
        p.x += p.vx;
        p.y += p.vy;
        p.vy += 0.3;
        p.life -= 0.015;

        ctx.globalAlpha = p.life;
        ctx.fillStyle = p.color;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
        ctx.fill();
      }

      if (alive) {
        requestAnimationFrame(animate);
      } else {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
      }
    }

    requestAnimationFrame(animate);
  }

  function createBalloon(letter: string): HTMLDivElement {
    const balloon = document.createElement('div');
    balloon.className = 'balloon';
    balloon.textContent = letter;
    balloon.dataset.letter = letter;

    const stage = calculateStage(score);
    const speedMult = 1 - ((stage - 1) * 0.05);

    const xPosition = 5 + Math.random() * 80;
    const minDur = BASE_FLOAT_MIN * speedMult;
    const maxDur = BASE_FLOAT_MAX * speedMult;
    const duration = minDur + Math.random() * (maxDur - minDur);
    const drift = (Math.random() - 0.5) * 60;

    balloon.style.setProperty('--x-position', `${xPosition}%`);
    balloon.style.setProperty('--drift', `${drift}px`);
    balloon.style.animationDuration = `${duration}s`;
    balloon.style.animationDelay = '0s';

    balloon.addEventListener('click', () => handleBalloonClick(balloon, letter));
    balloon.addEventListener('touchstart', (e) => {
      e.preventDefault();
      handleBalloonClick(balloon, letter);
    }, { passive: false });

    balloon.addEventListener('animationend', (e) => {
      if ((e as AnimationEvent).animationName !== 'float-up') return;
      balloon.remove();
    });

    return balloon;
  }

  function liveBalloons(): HTMLDivElement[] {
    return Array.from(balloonField.querySelectorAll('.balloon:not(.popping)')) as HTMLDivElement[];
  }

  function pickSpawnLetter(): string {
    const live = liveBalloons();
    const missingTargets = targetsToPop.filter(t => !live.some(b => b.dataset.letter === t));
    
    if (missingTargets.length > 0) {
      return missingTargets[0];
    }
    
    if (Math.random() < 0.3 && targetsToPop.length > 0) {
      return targetsToPop[Math.floor(Math.random() * targetsToPop.length)];
    }
    
    const pool = LETTERS.filter((l) => !targetLetters.includes(l));
    return pool[Math.floor(Math.random() * pool.length)];
  }

  function spawnTick() {
    if (!roundActive) return;
    const config = getStageConfig(calculateStage(score));
    const live = liveBalloons();
    
    // Strict cull of any accidental extra balloons (e.g. from HMR duplicate intervals)
    if (live.length > config.maxBalloons) {
      for (let i = config.maxBalloons; i < live.length; i++) {
        live[i].remove();
      }
    }
    
    if (live.length >= config.maxBalloons) return;
    
    const letter = pickSpawnLetter();
    balloonField.appendChild(createBalloon(letter));
  }

  function startSpawning() {
    stopSpawning();
    const stage = calculateStage(score);
    const config = getStageConfig(stage);
    spawnTimer = window.setInterval(spawnTick, config.spawnRate);
  }

  function stopSpawning() {
    if (spawnTimer !== null) {
      window.clearInterval(spawnTimer);
      spawnTimer = null;
    }
  }

  function handleBalloonClick(balloon: HTMLDivElement, letter: string) {
    if (!roundActive) return;
    if (balloon.classList.contains('popping') || balloon.classList.contains('wobble')) return;

    if (targetsToPop.includes(letter)) {
      balloon.classList.add('popping');
      playPop();
      
      targetsToPop = targetsToPop.filter(l => l !== letter);

      if (targetsToPop.length === 0) {
        roundActive = false;
        stopSpawning();
        setTimeout(playCheer, 150);
        spawnConfetti();
        score++;
        saveScore('balloon-pop', score);
        updateStats();
        nextBtn.classList.remove('hidden');
      }
    } else {
      balloon.classList.add('wobble');
      playBoing();
      setTimeout(() => balloon.classList.remove('wobble'), 400);
    }
  }

  function sayPrompt() {
    if (targetLetters.length === 1) {
      speakLetter(targetLetters[0]);
    } else {
      let promptText = "";
      if (targetLetters.length === 2) {
        promptText = `${targetLetters[0]} and ${targetLetters[1]}`;
      } else {
        const last = targetLetters[targetLetters.length - 1];
        const rest = targetLetters.slice(0, -1);
        promptText = `${rest.join(', ')}, and ${last}`;
      }
      speakPhrase(`Find the letters ${promptText}`);
    }
  }

  function startRound() {
    stopSpawning();
    roundActive = true;
    nextBtn.classList.add('hidden');
    balloonField.innerHTML = '';

    const stage = calculateStage(score);
    const config = getStageConfig(stage);

    targetLetters = shuffle(LETTERS).slice(0, config.targets);
    targetsToPop = [...targetLetters];

    let promptText = "";
    if (targetLetters.length === 1) {
      promptLabel.textContent = "Find the letter";
      promptText = targetLetters[0];
    } else if (targetLetters.length === 2) {
      promptLabel.textContent = "Find the letters";
      promptText = `${targetLetters[0]} & ${targetLetters[1]}`;
    } else {
      promptLabel.textContent = "Find the letters";
      const last = targetLetters[targetLetters.length - 1];
      const rest = targetLetters.slice(0, -1);
      promptText = `${rest.join(', ')} & ${last}`;
    }
    targetEl.textContent = promptText;

    const speedMult = 1 - ((stage - 1) * 0.05);
    const minDur = BASE_FLOAT_MIN * speedMult;

    const seedCount = Math.min(config.maxBalloons, config.targets + 2);
    const seedLetters = [...targetLetters];
    const pool = shuffle(LETTERS.filter((l) => !targetLetters.includes(l)));
    for (let i = seedLetters.length; i < seedCount; i++) seedLetters.push(pool.pop()!);

    shuffle(seedLetters).forEach((letter) => {
      const balloon = createBalloon(letter);
      balloon.style.animationDelay = `-${Math.random() * (minDur * 0.6)}s`;
      balloonField.appendChild(balloon);
    });

    startSpawning();
    sayPrompt();
  }

  speakBtn.addEventListener('click', sayPrompt);

  nextBtn.addEventListener('click', () => {
    startRound();
  });

  startRound();
</script>
